{
  "name": "golf-coach-v2",
  "version": "1.0.0",
  "description": "高爾夫預約系統 - LINE + LIFF + Firebase",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "bump:liff-version": "node scripts/bump-liff-version.js",
    "setup:rich-menu": "python scripts/generate-richmenu-images.py && node scripts/setup-rich-menus.js --env-file env.production.yaml"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@line/bot-sdk": "^9.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^4.28.0",
    "firebase-admin": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
