# Cloud Run 環境變數範本
# 1. 複製此檔案並重新命名為 env.production.yaml
# 2. 填入您的實際數值
# 3. 部署時使用：--env-vars-file env.production.yaml
# 4. 請將 env.production.yaml 加入 .gitignore，勿提交到 Git

LINE_CHANNEL_ACCESS_TOKEN: "您的Channel_Access_Token"
LINE_CHANNEL_SECRET: "您的Channel_Secret"
LIFF_COACH_ID: "您的教練LIFF_ID"
LIFF_STUDENT_ID: "您的學員LIFF_ID"
CRON_SECRET: "您的Cron密鑰"
COACH_LINE_USER_IDS: "您的LINE_User_ID"
